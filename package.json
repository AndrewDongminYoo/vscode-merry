{
  "name": "vscode-merry",
  "displayName": "Merry Scripts",
  "description": "An extension that lets you view the merry (a.k.a. derry) script at a glance in the VSCode sidebar and run it with a single click",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "workspaceContains:pubspec.yaml",
    "workspaceContains:merry.yaml",
    "workspaceContains:derry.yaml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-merry.runScript",
        "title": "Run Script",
        "category": "Merry",
        "icon": "$(play)"
      },
      {
        "command": "vscode-merry.refresh",
        "title": "Refresh Scripts",
        "category": "Merry",
        "icon": "$(refresh)"
      },
      {
        "command": "vscode-merry.openScriptSource",
        "title": "Open Script Source",
        "category": "Merry",
        "icon": "$(go-to-file)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "merryScripts",
          "name": "Merry Scripts",
          "when": "workspaceContains:pubspec.yaml || workspaceContains:merry.yaml || workspaceContains:derry.yaml",
          "icon": "$(run-all)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "vscode-merry.refresh",
          "when": "view == merryScripts",
          "group": "navigation"
        },
        {
          "command": "vscode-merry.openScriptSource",
          "when": "view == merryScripts",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "vscode-merry.runScript",
          "when": "view == merryScripts && viewItem == script",
          "group": "inline"
        },
        {
          "command": "vscode-merry.runScript",
          "when": "view == merryScripts && viewItem == script",
          "group": "merry@1"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Merry Scripts",
      "properties": {
        "merry.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Merry Scripts extension."
        },
        "merry.reuseTerminal": {
          "type": "boolean",
          "default": false,
          "description": "Reuse an existing Merry terminal instead of creating a new one each time."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.19.15",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0"
  }
}
