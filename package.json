{
  "name": "vscode-merry-scripts",
  "displayName": "Merry/Derry Scripts",
  "description": "Discover and run merry/derry scripts directly from the VS Code Explorer.",
  "version": "0.1.3",
  "publisher": "dongminyu",
  "author": "Dongmin Yu <ydm2790@gmail.com> (https://github.com/AndrewDongminYoo)",
  "license": "MIT",
  "icon": "assets/icons/dart-scripts.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other",
    "Snippets"
  ],
  "keywords": [
    "dart",
    "flutter",
    "merry",
    "derry",
    "scripts",
    "task-runner"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/AndrewDongminYoo/vscode-merry.git"
  },
  "bugs": {
    "email": "ydm2790@gmail.com",
    "url": "https://github.com/AndrewDongminYoo/vscode-merry/issues"
  },
  "homepage": "https://github.com/AndrewDongminYoo/vscode-merry#readme",
  "activationEvents": [
    "workspaceContains:pubspec.yaml",
    "workspaceContains:merry.yaml",
    "workspaceContains:derry.yaml"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "merry.runScript",
        "title": "Run Script",
        "category": "Merry",
        "icon": "$(play)"
      },
      {
        "command": "merry.refresh",
        "title": "Refresh Scripts",
        "category": "Merry",
        "icon": "$(refresh)"
      },
      {
        "command": "merry.openScriptSource",
        "title": "Open Script Source",
        "category": "Merry",
        "icon": "$(go-to-file)"
      },
      {
        "command": "merry.installCli",
        "title": "Install merry CLI",
        "category": "Merry",
        "icon": "$(cloud-download)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "merryScripts",
          "name": "Merry Scripts",
          "icon": "$(run-all)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "merry.refresh",
          "when": "view == merryScripts",
          "group": "navigation"
        },
        {
          "command": "merry.openScriptSource",
          "when": "view == merryScripts",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "merry.runScript",
          "when": "view == merryScripts && viewItem == script",
          "group": "inline"
        },
        {
          "command": "merry.runScript",
          "when": "view == merryScripts && viewItem == script",
          "group": "merry@1"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Merry Scripts",
      "properties": {
        "merry.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable the Merry Scripts extension."
        },
        "merry.reuseTerminal": {
          "type": "string",
          "enum": [
            "never",
            "always",
            "ask"
          ],
          "enumDescriptions": [
            "Always create a new terminal for each script run.",
            "Reuse the existing Merry terminal if it is open.",
            "Ask each time whether to reuse or create a new terminal."
          ],
          "default": "never",
          "description": "Terminal reuse behavior when running merry scripts."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "vsce:package": "vsce package --no-dependencies",
    "vsce:publish": "vsce publish --no-dependencies",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "format": "prettier **/*.{js,ts,mjs,json} --write",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "25.6.0",
    "@types/vscode": "^1.115.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  }
}
